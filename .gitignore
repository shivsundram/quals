# =============================================================================
# Project gitignore for shivsundram/quals.
#
# What we DO commit:
#   - bench/results/   research history (small JSON + CSV per run)
#   - bench/sbatch/    SLURM wrapper script (NOT its logs)
#   - all source under bench/ and the README
#   - the lastz/ submodule pointer (the submodule has its own gitignore)
#
# What we DON'T commit (everything below).
# =============================================================================

# -----------------------------------------------------------------------------
# Regenerable benchmark inputs.
# -----------------------------------------------------------------------------
# Synthetic FASTAs from gen_data.py — re-create with `bench/bench.py --suite scaling`.
bench/data/

# Real mRNA fetches from NCBI E-utilities — re-create with `python3 bench/fetch_real_data.py`.
bench/data_real/

# UCSC reference genome 2bit + per-chromosome slice symlinks. The actual files
# live in /scratch2/shiv1/lastz-bench-data/. Re-create with `python3 bench/fetch_genomes.py`.
bench/data_genomes/

# -----------------------------------------------------------------------------
# Bench results — per-run output policy.
# -----------------------------------------------------------------------------
# We KEEP results/<run>/{manifest.json,summary.csv,runs/*.json,runs/*.stage.txt}.
# We DROP the raw lastz alignment files (can be huge for chromosome-scale runs;
# they're a function of the inputs which are themselves regenerable).
bench/results/**/*.lastz_out
bench/results/**/*.maf
bench/results/**/*.maf-
bench/results/**/*.axt
bench/results/**/*.lav
bench/results/**/*.sam

# eu-stack profile dumps. We KEEP folded.txt / top_funcs.txt / top_lines.txt /
# manifest.json (small, useful research history). We DROP per-sample raw stacks
# (hundreds of small files, ASLR-randomized PIE addresses make them
# host-specific anyway) and the alignment output of the profiled run.
bench/results/**/raw/
bench/results/**/lastz.out
bench/results/**/lastz.err

# -----------------------------------------------------------------------------
# SLURM artifacts.
# -----------------------------------------------------------------------------
bench/sbatch/logs/

# -----------------------------------------------------------------------------
# Python cruft.
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
build/
dist/

# Virtualenvs (none expected on this project, but defensive).
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# C / native build artifacts that might leak outside the lastz submodule.
# -----------------------------------------------------------------------------
*.o
*.a
*.so
*.dylib
*.d
core
core.[0-9]*
vgcore.*

# -----------------------------------------------------------------------------
# Editor / IDE / OS junk.
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
.bak
*.bak
*.tmp
*.orig
*.rej

# Cursor / agent local state, if any leaks into the workspace.
.cursor/

# -----------------------------------------------------------------------------
# Misc loose files.
# -----------------------------------------------------------------------------
*.log
nohup.out

# Scratch / one-off scripts. Drop a real script in bench/ instead.
scratch/
tmp/
.scratch/
